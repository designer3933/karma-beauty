<script>
document.addEventListener("DOMContentLoaded", function(){

  const NEXT_PAGE = "/pages/warranty-selection";
  const API_URL = "https://karma-beauty-two.vercel.app/api/sab";

  document.querySelectorAll(".next-btn").forEach(btn => {

    btn.addEventListener("click", async function(){

      const form = this.closest("form");
      const confirmation = form.querySelector(".confirmation_number").value.trim();
      const toolSelect = form.querySelector(".tool-select");

      let selectedTool = toolSelect.options[toolSelect.selectedIndex].text;

      // ==========================
      // CASE 1: Confirmation Number
      // ==========================
      if(confirmation){

        try{
          const res = await fetch(API_URL + "?warrentyid=" + encodeURIComponent(confirmation));
          const json = await res.json();

          if(json.data && json.data.length){

            const record = json.data[0];

            localStorage.setItem("selectedTool", record["Selected Tool"] || selectedTool);
            localStorage.setItem("customerData", JSON.stringify(record));

            window.location.href = NEXT_PAGE;

          } else {
            alert("Confirmation number not found");
          }

        } catch(e){
          alert("Error verifying number");
        }

      }

      // ==========================
      // CASE 2: Manual (FINAL FIX)
      // ==========================
      else{

        if(!form.checkValidity()){
          form.reportValidity();
          return;
        }

        const fileInput = form.querySelector(".receipt-file-input");
        let fileURL = "";

        // ✅ Upload image to Cloudinary
        if (fileInput && fileInput.files.length > 0) {

          const file = fileInput.files[0];

          // Validation
          const validTypes = ['image/jpeg','image/jpg','image/png','application/pdf'];
          const maxSize = 5 * 1024 * 1024;

          if (!validTypes.includes(file.type)) {
            alert("Invalid file type. Upload JPG, PNG or PDF.");
            return;
          }

          if (file.size > maxSize) {
            alert("File too large. Max 5MB allowed.");
            return;
          }

          const formData = new FormData();
          formData.append("file", file);
          formData.append("upload_preset", "warranty_video"); // same preset

          try{
            // Optional loading
            btn.innerText = "Uploading image...";
            btn.disabled = true;

            const res = await fetch(
              "https://api.cloudinary.com/v1_1/dmkvgg8vo/image/upload",
              {
                method: "POST",
                body: formData
              }
            );

            const data = await res.json();

            if(!data.secure_url){
              throw new Error();
            }

            fileURL = data.secure_url;

          } catch(e){
            alert("Image upload failed. Please try again.");
            btn.innerText = "Continue to Warranty";
            btn.disabled = false;
            return;
          }
        }

        const manualData = {
          fullName: form.querySelector(".full_name")?.value || "",
          email: form.querySelector(".email")?.value || "",
          purchaseDate: form.querySelector("#dateInput")?.value || "",
          selectedTool: selectedTool,
          Attachment: fileURL // ✅ FINAL FIX
        };

        localStorage.setItem("selectedTool", selectedTool);
        localStorage.setItem("customerData", JSON.stringify(manualData));

        window.location.href = NEXT_PAGE;
      }

    });

  });

});
</script>>
