<script>
document.addEventListener('DOMContentLoaded', function() {
  const dateInput = document.getElementById('purchase-date');

  // When user selects a date, reformat it visually to MM/DD/YYYY
  dateInput.addEventListener('change', function() {
    const [year, month, day] = this.value.split('-');
    if (year && month && day) {
      // Create formatted display
      const formatted = `${month}/${day}/${year}`;
      // Store real value separately
      this.setAttribute('data-original', this.value);
      // Replace displayed value
      this.type = 'text';
      this.value = formatted;
    }
  });

  // When clicking again, switch back to 'date' type to reopen the calendar
  dateInput.addEventListener('focus', function() {
    const original = this.getAttribute('data-original');
    this.type = 'date';
    if (original) this.value = original;
  });
});
</script>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const radioGroup = document.querySelectorAll('input[name="is_us_address"]');
    const hulkApp = document.getElementById('hulk-app-container');
    const warrantyOrder = document.getElementById('warranty-order-container');

    function toggleContainers() {
      console.info('Toggling containers...');

      let selectedValue = null;

      radioGroup.forEach(radio => {
        console.info(`Checking radio: id=${radio.id}, checked=${radio.checked}, value=${radio.value}`);
        if (radio.checked) {
          selectedValue = radio.value;
        }
      });

      console.info(`Selected value: ${selectedValue}`);

      if (selectedValue === 'yes') {
        console.info('User selected YES — hiding hulkApp, showing warrantyOrder');
        hulkApp.style.display = 'none';
        warrantyOrder.style.display = 'block';
      } else if (selectedValue === 'no') {
        console.info('User selected NO — showing hulkApp, hiding warrantyOrder');
        hulkApp.style.display = 'block';
        warrantyOrder.style.display = 'none';
      } else {
        console.info('No valid selection made');
      }
    }

    // Attach event listeners
    radioGroup.forEach(radio => {
      radio.addEventListener('change', toggleContainers);
    });

    // Optional: Trigger on load in case a radio is pre-selected
    toggleContainers();
  });
</script>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const selects = document.querySelectorAll('.tool-select');
    const forms = document.querySelectorAll('.product-form-wrapper');

    const sharedFields = [
      'first_name', 'last_name', 'email',
      'phone', 'purchase_location', 'purchase_date'
    ];

    // Sync inputs across all forms
    sharedFields.forEach(field => {
      const allInputs = document.querySelectorAll(`[name="properties[${field}]"]`);
      allInputs.forEach(input => {
        input.addEventListener('input', function () {
          const value = this.value;
          allInputs.forEach(target => {
            if (target !== this) {
              target.value = value;
            }
          });
        });
      });
    });

    // Handle file uploads with proper URL generation
    const fileInputs = document.querySelectorAll('.receipt-file-input');
    fileInputs.forEach(fileInput => {
      fileInput.addEventListener('change', function() {
        const file = this.files[0];
        const statusDiv = this.parentElement.querySelector('.file-upload-status');
        const urlInput = this.parentElement.querySelector('.receipt-url-input');
        
        if (file) {
          // Validate file
          const validTypes = ['image/jpeg', 'image/jpg', 'image/png', 'application/pdf'];
          const maxSize = 5 * 1024 * 1024; // 5MB
          
          if (!validTypes.includes(file.type)) {
            statusDiv.style.display = 'block';
            statusDiv.style.color = '#d11a1a';
            statusDiv.textContent = 'Invalid file type. Please upload JPG, PNG, or PDF.';
            this.value = '';
            urlInput.value = '';
            return;
          }
          
          if (file.size > maxSize) {
            statusDiv.style.display = 'block';
            statusDiv.style.color = '#d11a1a';
            statusDiv.textContent = 'File too large. Maximum size is 5MB.';
            this.value = '';
            urlInput.value = '';
            return;
          }
          
          // Show upload status
          statusDiv.style.display = 'block';
          statusDiv.style.color = '#d1d1d1';
          statusDiv.textContent = `File selected: ${file.name} (${(file.size / 1024 / 1024).toFixed(2)}MB)`;
          
          // Create object URL for the file
          const fileURL = URL.createObjectURL(file);
          urlInput.value = fileURL;
          
          // Sync file across all forms
          fileInputs.forEach(otherInput => {
            if (otherInput !== this) {
              // Create a new FileList with the same file
              const dt = new DataTransfer();
              dt.items.add(file);
              otherInput.files = dt.files;
              
              // Update status for other forms
              const otherStatusDiv = otherInput.parentElement.querySelector('.file-upload-status');
              const otherUrlInput = otherInput.parentElement.querySelector('.receipt-url-input');
              
              if (otherStatusDiv) {
                otherStatusDiv.style.display = 'block';
                otherStatusDiv.style.color = '#d1d1d1';
                otherStatusDiv.textContent = `File selected: ${file.name} (${(file.size / 1024 / 1024).toFixed(2)}MB)`;
              }
              
              if (otherUrlInput) {
                otherUrlInput.value = fileURL;
              }
            }
          });
        } else {
          statusDiv.style.display = 'none';
          urlInput.value = '';
          
          // Clear file from other forms too
          fileInputs.forEach(otherInput => {
            if (otherInput !== this) {
              otherInput.value = '';
              const otherStatusDiv = otherInput.parentElement.querySelector('.file-upload-status');
              const otherUrlInput = otherInput.parentElement.querySelector('.receipt-url-input');
              
              if (otherStatusDiv) {
                otherStatusDiv.style.display = 'none';
              }
              
              if (otherUrlInput) {
                otherUrlInput.value = '';
              }
            }
          });
        }
      });
    });

    // Function to switch active form and update variant
    function switchToForm(targetProductId) {
      console.log('Switching to product:', targetProductId);
      
      forms.forEach(form => {
        if (form.dataset.productId === targetProductId) {
          form.style.display = 'block';
          
          // Find the corresponding select and update variant
          const select = form.querySelector('.tool-select');
          const selectedOption = select.options[select.selectedIndex];
          const variantId = selectedOption.dataset.variantId;
          
          if (variantId) {
            const variantInput = form.querySelector('.variant-id-input');
            if (variantInput) {
              variantInput.value = variantId;
              console.log('Updated variant ID to:', variantId);
            }
          }
        } else {
          form.style.display = 'none';
        }
      });
    }

    // Handle select changes
    selects.forEach(select => {
      select.addEventListener('change', function () {
        const selectedOption = this.options[this.selectedIndex];
        const targetProductId = selectedOption.dataset.targetid;
        const variantId = selectedOption.dataset.variantId;
        
        console.log('Product selected:', selectedOption.value, 'Target ID:', targetProductId, 'Variant ID:', variantId);
        
        // Sync all selects to show same selection
        selects.forEach(otherSelect => {
          if (otherSelect !== this) {
            otherSelect.value = this.value;
          }
        });
        
        // Switch to the target form
        switchToForm(targetProductId);
      });
    });

    // Initialize: ensure first form has correct variant ID
    if (forms.length > 0) {
      const firstForm = forms[0];
      const firstSelect = firstForm.querySelector('.tool-select');
      if (firstSelect) {
        const selectedOption = firstSelect.options[firstSelect.selectedIndex];
        const variantId = selectedOption.dataset.variantId;
        if (variantId) {
          const variantInput = firstForm.querySelector('.variant-id-input');
          if (variantInput) {
            variantInput.value = variantId;
            console.log('Initial variant ID set to:', variantId);
          }
        }
      }
    }

    // Form submission handling
    document.querySelectorAll('.warranty-product-form').forEach(form => {
      form.addEventListener('submit', function(e) {
        const variantInput = this.querySelector('.variant-id-input');
        const variantId = variantInput ? variantInput.value : null;
        const fileInput = this.querySelector('.receipt-file-input');
        const urlInput = this.querySelector('.receipt-url-input');
        const confirmation_number = this.querySelector('.confirmation_number');

        console.log('Form submission - Variant ID:', variantId);
        
        if (!variantId) {
          e.preventDefault();
          alert('Error: Product variant not found. Please refresh the page and try again.');
          return false;
        }
        
        // Check if file is uploaded
        if(confirmation_number && confirmation_number.value === ""){
          if (fileInput && fileInput.files.length === 0) {
            e.preventDefault();
            //alert('Please upload a receipt proof file before submitting.');
            return false;
          }
        }

        // Add file URL to form data if available
        if (urlInput && urlInput.value) {
          console.log('Receipt file URL:', urlInput.value);
        }
        
        // Log all form data for debugging
        const formData = new FormData(this);
        console.log('Form data being submitted:');
        for (let [key, value] of formData.entries()) {
          console.log(`${key}: ${value}`);
        }

      });
    });
    
  });


  $('.warranty-product-form').on('submit', function (e) {
    e.preventDefault();

    var formData = new FormData(this);
    var confirmationNumber = $('.confirmation_number').val();
    var fileInput = document.querySelector('.receipt-file-input');
    var hasFile = fileInput && fileInput.files.length > 0;

    if (!confirmationNumber && !hasFile) {
      alert('Please enter a confirmation number or upload a receipt.');
      return;
    }

    $.ajax({
      url: '/cart/add',
      type: 'POST',
      data: formData,
      processData: false,
      contentType: false,
      success: function () {
        window.location.href = '/checkout';
      },
      error: function (err) {
        console.error('Error adding to cart:', err);
        alert('Oops! Something went wrong.');
      }
    });
  });


</script>




