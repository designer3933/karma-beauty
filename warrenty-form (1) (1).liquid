            }
          }
          
          if (!matched) {
            console.warn("✗ Could not match tool:", record["Selected Tool"]);
            console.warn("Normalized Airtable value was:", normalizedAirtable);
          }
        }

        // Wait a bit for form switch to complete, then fill other fields
        setTimeout(function() {
          // Get the currently visible form (after switch)
          var visibleForm = document.querySelector('.product-form-wrapper[style*="display: block"], .product-form-wrapper:not([style*="display: none"])');
          if (!visibleForm) visibleForm = currentForm;
          
          // Fill Full Name and Email in the visible form
          var fullNameInput = visibleForm.querySelector(".full_name");
          var emailInput = visibleForm.querySelector(".email");
          if (fullNameInput) fullNameInput.value = record["Full Name"] || "";
          if (emailInput) emailInput.value = record["Email"] || "";

          // Fill Date (Airtable returns YYYY-MM-DD which matches date input format)
          var dateInput = visibleForm.querySelector("#dateInput");
          if (dateInput && record["Date"]) {
            dateInput.value = record["Date"];
          }

          // Show attachment link if available
          var fileDivVisible = visibleForm.querySelector(".previous-file-link");
          if (fileDivVisible && record["Attachment"]) {
            fileDivVisible.style.display = "block";
            fileDivVisible.innerHTML = 'Previous upload on file: <a href="' + record["Attachment"] + '" target="_blank" style="color:#d1d1d1;text-decoration:underline;">View file</a>';
          }

          var statusDivVisible = visibleForm.querySelector(".verify-status");
          if (statusDivVisible) {
            statusDivVisible.style.display = "block";
            statusDivVisible.style.color = "#3d9c56";
            statusDivVisible.textContent = "Details loaded successfully.";
          }

          console.log("Auto filled from Airtable:", record);
        }, 300); // 300ms delay to allow form switch to complete

      })
      .catch(function(err) {
        console.error("Verify error:", err);
        if (statusDiv) {
          statusDiv.style.color = "#d11a1a";
          statusDiv.textContent = "Error fetching details. Please try again.";
        }
      });
  }

  // Verify button click
  document.querySelectorAll(".verify-btn").forEach(function(btn) {
    btn.addEventListener("click", function() {
      var input = this.closest(".form_field").querySelector(".confirmation_number");
      if (input) verifyConfirmationNumber(input, false);
    });
  });

  // Also trigger on blur (when user tabs away from the field)
  document.querySelectorAll(".confirmation_number").forEach(function(input) {
    input.addEventListener("blur", function() {
      if (this.value.trim()) verifyConfirmationNumber(this, false);
    });
  });

  // Auto-verify from URL parameter ?wid=
  var urlParams = new URLSearchParams(window.location.search);
  var widParam = urlParams.get('wid');
  
  if (widParam) {
    console.log("Found ?wid= in URL:", widParam);
    
    // Fill the confirmation number in all forms
    document.querySelectorAll(".confirmation_number").forEach(function(input) {
      input.value = widParam;
    });
    
    // Auto-verify using the first form's input
    var firstConfirmationInput = document.querySelector(".confirmation_number");
    if (firstConfirmationInput) {
      verifyConfirmationNumber(firstConfirmationInput, true);
    }
  }

});


</script>  {% endcomment %}

